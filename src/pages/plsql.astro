---
import Layout from "../layouts/Layout.astro";
import PlsqlViewer from "../React/PlsqlViewer";
---

<Layout title="PL/SQL">

<section class="max-w-6xl mx-auto py-10 px-4">

  <div class="flex items-center justify-between mb-10">
  
  <h1 class="text-4xl font-bold text-white">
    Evidencias — PL/SQL
  </h1>

  <!-- ICONO GITHUB -->
  <a 
    href="https://github.com/nicolasmatheus71/pl-sql-scripts"
    target="_blank"
    rel="noopener noreferrer"
    class="opacity-60 hover:opacity-100 hover:scale-110 transition-all duration-300"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="white" viewBox="0 0 24 24" class="w-8 h-8 md:w-9 md:h-9">
      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2.2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.6-1.3-1.6-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1.1.1-.8.4-1.4.7-1.7-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.7 3.7 18.7 4 18.7 4c.7 1.7.2 3 .1 3.3.8.9 1.3 2 1.3 3.2 0 4.4-2.7 5.4-5.3 5.7.4.3.8 1 .8 2v3c0 .3.2.7.8.6A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/>
    </svg>
  </a>

</div>

  <PlsqlViewer client:load />

</section>

</Layout>